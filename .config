# 机型：mt7986 闭源专用
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7986=y
CONFIG_TARGET_mediatek_mt7986_DEVICE_cmcc_rax3000m=y

# 闭源驱动 + HNAT硬件加速
CONFIG_PACKAGE_kmod-mt-wifi=y
CONFIG_PACKAGE_kmod-mt7986-firmware=y
CONFIG_PACKAGE_kmod-hnat=y
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_mtwifi-opkg=y
CONFIG_PACKAGE_wpad-openssl=y

# 基础系统
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_iptables-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_autocore=y

# 内核优化
CONFIG_PACKAGE_kmod-sched-fq-codel=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y

# USB & 文件系统
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb3=y

# USB 共享打印机
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_p910nd=y
CONFIG_PACKAGE_luci-app-p910nd=y

# 主题
CONFIG_PACKAGE_luci-theme-argon=y

# 常用插件
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-wireguard=y

# OpenList
CONFIG_PACKAGE_luci-app-openlist=y

# OpenClash
CONFIG_PACKAGE_luci-app-openclash=y

# LuCI 兼容
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
